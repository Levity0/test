{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "rewrites": [
    { "source": "/home", "destination": "/server/index.js" },
    { "source": "/search", "destination": "/server/index.js" },
    { "source": "/api/:match*", "destination": "/server/index.js" }
  ]
}
